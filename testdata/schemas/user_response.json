{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "用户接口响应 Schema",
    "description": "用于校验用户相关接口的响应结构",
    "type": "object",
    "required": ["code", "message", "data"],
    "properties": {
        "code": {
            "type": "integer",
            "description": "响应状态码，0 表示成功"
        },
        "message": {
            "type": "string",
            "description": "响应消息"
        },
        "data": {
            "type": ["object", "null"],
            "properties": {
                "user_id": {"type": "string"},
                "username": {"type": "string"},
                "email": {"type": "string", "format": "email"},
                "created_at": {"type": "string"}
            }
        }
    }
}
